{
  "name": "embedded",
  "version": "2.1.0",
  "description": "Para criar o componente de assinatura:",
  "engines": {
    "node": "^18.18.0"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "esbuild": "^0.25.5"
  },
  "scripts": {
    "build:widget:legacy": "esbuild packages/widget/legacy/src/embedded.js --minify --outdir=build",
    "build:widget": "esbuild packages/widget/index.js --bundle --sourcemap --minify --keep-names --target=safari15 --outfile=build/widget/embedded.js",
    "build:verify": "esbuild packages/verify/index.js --bundle --sourcemap --minify --keep-names --target=safari15 --outfile=build/verify/embedded.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clicksign/embedded.git"
  },
  "author": "Daniel Libanori",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/clicksign/embedded/issues"
  },
  "homepage": "https://github.com/clicksign/embedded#readme"
}
